# NextAuth
NEXTAUTH_SECRET=your-secret-here
NEXTAUTH_URL=http://localhost:3000

# Database (SQLite local — swap to PostgreSQL for Supabase)
DATABASE_URL="file:./dev.db"

# Resend (email verification, password reset)
RESEND_API_KEY=re_your_key_here
RESEND_FROM_EMAIL=noreply@yourdomain.com

# OpenAI (job matching & recommendations)
OPENAI_API_KEY=sk-your_key_here

# JSearch API via RapidAPI
RAPIDAPI_KEY=your_rapidapi_key_here
JSEARCH_API_HOST=jsearch.p.rapidapi.com

# Adzuna API
ADZUNA_APP_ID=your_adzuna_app_id
ADZUNA_API_KEY=your_adzuna_api_key

# USA Jobs API (no key required — just app name + email)
USAJOBS_USER_AGENT=JobSearchDashboard/1.0
USAJOBS_AUTH_KEY=your_usajobs_auth_key

# Upstash Redis (rate limiting)
UPSTASH_REDIS_REST_URL=https://your-upstash-endpoint.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token

# Gmail API (read-only OAuth)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Microsoft Graph API (Outlook, read-only OAuth)
MICROSOFT_CLIENT_ID=your_microsoft_client_id
MICROSOFT_CLIENT_SECRET=your_microsoft_client_secret

# Apollo.io or Hunter.io (outreach contact finder)
APOLLO_API_KEY=your_apollo_api_key
HUNTER_API_KEY=your_hunter_api_key
